    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "eslint": "^8.56.0"
  },
  "packageManager": "pnpm@9.0.0"
}
