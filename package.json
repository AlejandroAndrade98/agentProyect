{
  "name": "sales-ai-platform",
  "private": true,
  "engines": {
    "node": ">=20 <21",
    "pnpm": "9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start:api": "pnpm --filter @sales-ai/api start",
    "start:web": "pnpm --filter @sales-ai/web start",
    "start:worker": "pnpm --filter @sales-ai/worker start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "check:generated": "node scripts/check-clean-generated-files.mjs",
    "smoke:static": "node scripts/smoke-static.mjs",
    "smoke:runtime": "node scripts/smoke-runtime.mjs",
    "db:validate": "node scripts/prisma-host.mjs validate",
    "db:migrate": "node scripts/prisma-host.mjs migrate dev",
    "db:generate": "node scripts/prisma-host.mjs generate",
    "db:studio": "node scripts/prisma-host.mjs studio",
    "db:deploy": "node scripts/prisma-host.mjs migrate deploy"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "eslint": "^8.56.0"
  },
  "packageManager": "pnpm@9.0.0"
}
