# Sales AI Platform environment example
# Copy to .env for local Docker/dev. For staging/production, set values in the
# deployment provider or secret manager. Never commit real secrets.

# --- Node / runtime ---
NODE_ENV=development

# --- API ---
# Managed providers may inject PORT. The API reads PORT first, then API_PORT.
# Keep API_PORT for local Docker/dev and manual provider configuration.
API_PORT=4000
# Maximum JSON/urlencoded request body size accepted by the API.
REQUEST_BODY_LIMIT=1mb

# --- Web / frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Optional documentation-only value for deployment runbooks and OAuth setup.
FRONTEND_URL=http://localhost:3000

# --- CORS ---
# Comma-separated browser origins allowed to call the API.
# The first origin is also used by the Google OAuth callback redirect.
CORS_ORIGIN=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sales_ai_db?schema=public
# Host-side URL used only by local Prisma scripts when running outside Docker.
# Do not set DATABASE_URL_HOST in hosted staging/production providers.
DATABASE_URL_HOST=postgresql://postgres:postgres@localhost:15432/sales_ai_db?schema=public
POSTGRES_DB=sales_ai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis / queues ---
# Redis is present for worker/future queue architecture. Background jobs are not
# enabled yet.
REDIS_URL=redis://redis:6379
REDIS_URL_HOST=redis://localhost:16379

# --- Auth / JWT ---
JWT_ACCESS_SECRET=replace_with_strong_access_token_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_token_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Staging bootstrap admin (one-off) ---
# Use only for the first deployed empty staging database. Remove password/env
# values from the provider after running the one-off command.
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ORGANIZATION_NAME=
BOOTSTRAP_ADMIN_ROLE=OWNER
BOOTSTRAP_ALLOW_EXISTING_USERS=false
BOOTSTRAP_UPDATE_EXISTING_PASSWORD=false

# --- Auth recovery ---
# Dev-only mode returns a reset URL in the API response for local testing.
# Production validation rejects AUTH_RECOVERY_DEV_MODE=true.
AUTH_RECOVERY_DEV_MODE=false
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# Optional absolute frontend reset URL base. Defaults to FRONTEND_URL.
PASSWORD_RESET_PUBLIC_URL=http://localhost:3000

# --- Google OAuth / connected accounts ---
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/connected-accounts/oauth/google/callback
# Backward-compatible aliases also supported by the API:
# GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/connected-accounts/oauth/google/callback

# Must be base64 for exactly 32 random bytes. Example generation:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTED_ACCOUNT_TOKEN_ENCRYPTION_KEY=replace_with_32_byte_base64_key
CONNECTED_ACCOUNT_TOKEN_ENCRYPTION_KEY_VERSION=v1
# Backward-compatible legacy name also supported by the API:
# CONNECTED_ACCOUNT_TOKEN_ENCRYPTION_VERSION=v1

# --- AI provider ---
# options: mock, openai
AI_PROVIDER=mock
OPENAI_API_KEY=replace_with_openai_api_key_when_using_openai
OPENAI_MODEL=gpt-5.5
AI_MAX_INPUT_CHARS=10000

# --- Sync behavior placeholders ---
# Current Gmail/Calendar sync is explicit/manual. Future background workers may
# use these values.
SYNC_GMAIL_ENABLED=false
SYNC_CALENDAR_ENABLED=false
SYNC_WORKER_CONCURRENCY=1

# --- Logging / monitoring placeholders ---
LOG_LEVEL=info
REQUEST_LOGGING_ENABLED=true
LOG_FORMAT=json
LOG_REDACT_SENSITIVE=true
SENTRY_DSN=
MONITORING_ENVIRONMENT=local

# --- Storage & paths ---
EXPORTS_DIR=./infra/docker/exports
BACKUPS_DIR=./infra/docker/backups

# --- Retention policies (days) ---
RETENTION_AI_PENDING_DAYS=30
RETENTION_AI_REJECTED_DAYS=30
RETENTION_PROMPT_TEXT_DAYS=30
RETENTION_TECHNICAL_LOGS_DAYS=30
RETENTION_AUDIT_LOGS_DAYS=365
RETENTION_EXPORT_FILES_DAYS=7
